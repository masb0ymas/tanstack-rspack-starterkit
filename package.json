{
  "name": "tanstack-rspack-hono",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:web\" \"bun run dev:server\"",
    "dev:web": "rsbuild dev --open",
    "dev:server": "tsx watch server/index.ts",
    "clean": "rimraf dist dist-server client",
    "prebuild": "bun run clean",
    "build": "bun run build:web && bun run build:server",
    "build:web": "rsbuild build",
    "build:server": "tsc -p tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "serve:standalone": "chmod +x script/standalone.sh && ./script/standalone.sh",
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "check": "bun run format && bun run lint",
    "preview": "rsbuild preview",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.3",
    "axios": "^1.14.0",
    "better-auth": "^1.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "colorette": "^2.0.20",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "hono": "^4.10.1",
    "lodash": "^4.17.23",
    "lucide-react": "^1.7.0",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rimraf": "^6.1.3",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@rsbuild/core": "^1.7.1",
    "@rsbuild/plugin-react": "^1.4.2",
    "@rstest/core": "^0.7.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/router-plugin": "^1.167.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "happy-dom": "^20.0.11",
    "husky": "^9.1.7",
    "prettier": "^3.7.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
